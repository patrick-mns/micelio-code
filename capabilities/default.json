{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core permissions for the main window: custom commands plus the event system (listen/emit) used for chat streaming.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-internal-toggle-maximize",
    "core:webview:default",
    "core:app:default",
    "dialog:default",
    "dialog:allow-open"
  ]
}
